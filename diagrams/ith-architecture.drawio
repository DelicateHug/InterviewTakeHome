<mxfile host="app.diagrams.net" type="device">
  <diagram name="1. Org &amp; Guardrails" id="ith-page-1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title + key ===== -->
        <mxCell id="p1-title" value="Page 1 &#8212; AWS Organization &amp; Guardrails (SCP + RCP)" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p1-sub" value="Isolation discipline: SCP + RCP attach to the InterviewTakeHome OU ONLY. Existing accounts &amp; identities are untouched. (R6, R8, R9)" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;whiteSpace=wrap;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1000" height="22" as="geometry" />
        </mxCell>

        <!-- ===== Org root ===== -->
        <mxCell id="p1-org" value="[01] AWS Organization &#8212; o-ncxqr8pp2c&#10;(FeatureSet ALL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="110" width="520" height="64" as="geometry" />
        </mxCell>

        <mxCell id="p1-root" value="[02] Org Root &#8212; r-33e3&#10;Policy types ENABLED: SERVICE_CONTROL_POLICY (SCP) + RESOURCE_CONTROL_POLICY (RCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="600" height="64" as="geometry" />
        </mxCell>

        <!-- ===== Management account ===== -->
        <mxCell id="p1-mgmt" value="[03] Management account &#8212; 337066574719&#10;(&quot;Managment&quot;, dylanheathsmart@gmail.com)&#10;Hosts: Identity Center instance (see Page 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="360" width="420" height="84" as="geometry" />
        </mxCell>

        <!-- ===== OU container ===== -->
        <mxCell id="p1-ou" value="[04] OU: InterviewTakeHome &#8212; ou-33e3-5p8xygxw&#10;(isolated; the ONLY attach target for the SCP &amp; RCP below)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#eef5ff;strokeColor=#6c8ebf;dashed=1;fontStyle=1;fontSize=14;container=1;collapsible=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="360" width="900" height="620" as="geometry" />
        </mxCell>

        <!-- member account inside OU -->
        <mxCell id="p1-acct" value="[05] Member account: ith-workload &#8212; 118821711925&#10;(dylanheathsmart+ith-workload@gmail.com)&#10;Region ap-southeast-1 &#183; all workload + data-plane resources (Page 2)&#10;CloudTrail / GuardDuty / alarms are account-level (Page 4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;verticalAlign=top;spacingTop=6;" vertex="1" parent="p1-ou">
          <mxGeometry x="40" y="60" width="500" height="120" as="geometry" />
        </mxCell>

        <!-- SCP -->
        <mxCell id="p1-scp" value="[06] SCP: ith-scp-s3-guardrails&#10;(identity/permission guardrail &#8212; what principals in the OU may DO)&#10;&#8226; Deny s3:* unless aws:SecureTransport=true (TLS required)&#10;&#8226; Deny s3:PutObject on phi-* unless SSE = aws:kms (SSE-KMS required)&#10;&#8226; Deny s3:PutBucketPublicAccessBlock / disabling BPA (protect Block Public Access)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p1-ou">
          <mxGeometry x="40" y="230" width="820" height="150" as="geometry" />
        </mxCell>

        <!-- RCP -->
        <mxCell id="p1-rcp" value="[07] RCP: ith-rcp-s3-org-only&#10;(resource guardrail &#8212; who, from ANYWHERE, may touch resources in the OU)&#10;&#8226; Deny s3:* unless aws:PrincipalOrgID == o-ncxqr8pp2c&#10;&#8226; Blocks any principal OUTSIDE this org (confused-deputy / cross-account exfil)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p1-ou">
          <mxGeometry x="40" y="410" width="820" height="120" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="p1-e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p1-org" target="p1-root">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e2" value="contains" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;fontSize=11;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p1-root" target="p1-mgmt">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="650" y="320" /><mxPoint x="330" y="320" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="p1-e3" value="contains OU" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;fontSize=11;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p1-root" target="p1-ou">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="950" y="330" /></Array></mxGeometry>
        </mxCell>
        <!-- SCP attaches to OU (applies to member account) -->
        <mxCell id="p1-e-scp" value="attached to OU &#8594; applies to acct" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#82b366;fontSize=11;fontStyle=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="p1-scp" target="p1-acct">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="845" y="565" /></Array></mxGeometry>
        </mxCell>
        <!-- RCP attaches to OU (applies to member account) -->
        <mxCell id="p1-e-rcp" value="attached to OU &#8594; applies to acct" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#d79b00;fontSize=11;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p1-rcp" target="p1-acct">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1480" y="830" /><mxPoint x="1480" y="480" /></Array></mxGeometry>
        </mxCell>

        <!-- ===== Legend ===== -->
        <mxCell id="p1-legend" value="LEGEND &amp; NOTES&#10;&#8226; [02] Org root r-33e3 has BOTH policy types enabled; policies attach to the OU [04] only (blast-radius = this OU).&#10;&#8226; SCP [06] = identity guardrail (a ceiling on what principals IN the OU can DO). RCP [07] = resource guardrail (who, from anywhere, can touch RESOURCES in the OU).&#10;&#8226; Together they enforce: TLS-only, SSE-KMS on phi-* puts, BPA stays on (R8) and S3 reachable by org principals only (R9).&#10;&#8226; Requirements: R6 (1 mgmt + 1 OU + 1 member acct), R8 (SCP), R9 (RCP). Controls doc: docs/design.md." style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="640" width="440" height="200" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2. Data Plane (4 paths)" id="ith-page-2">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="p2-title" value="Page 2 &#8212; Data Plane: 4 controlled paths to the sensitive bucket (R1, R7, R15, R16, R17, C1&#8211;C4)" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p2-sub" value="Account ith-workload 118821711925 &#183; ap-southeast-1 &#183; primary flow runs left &#8594; right toward [20] phi-sensitive. Colors: blue=compute, green=path, orange=network/endpoint, purple=KMS, red=data." style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;whiteSpace=wrap;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1600" height="22" as="geometry" />
