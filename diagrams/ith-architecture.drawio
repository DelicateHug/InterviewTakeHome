        <mxCell id="p2-eP2b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-peer" target="p2-if-s3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="940" y="325" /><mxPoint x="940" y="445" /></Array></mxGeometry>
        </mxCell>
        <!-- P3: EC2 -> gateway endpoint -->
        <mxCell id="p2-eP3" value="P3 human read (instance role)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="p2-wl" source="p2-ec2" target="p2-gw">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="385" y="240" /></Array></mxGeometry>
        </mxCell>
        <!-- P4: s3 role -> gateway endpoint (gated sourceVpce) -->
        <mxCell id="p2-eP4" value="P4 direct read (gated aws:sourceVpce)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="p2-wl" source="p2-s3role" target="p2-gw">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="385" y="365" /></Array></mxGeometry>
        </mxCell>
        <!-- P1: lambda -> OLAP -->
        <mxCell id="p2-eP1" value="P1 redactor reads" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="p2-wl" source="p2-lambda" target="p2-olap">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- gateway endpoint -> sensitive bucket -->
        <mxCell id="p2-egw-s3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-gw" target="p2-sensitive">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1300" y="430" /><mxPoint x="1300" y="300" /></Array></mxGeometry>
        </mxCell>
        <!-- interface endpoint -> sensitive bucket -->
        <mxCell id="p2-eif-s3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-if-s3" target="p2-sensitive">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1340" y="445" /><mxPoint x="1340" y="260" /></Array></mxGeometry>
        </mxCell>
        <!-- OLAP -> sensitive bucket (supporting AP) -->
        <mxCell id="p2-eolap-s3" value="supporting access point" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;strokeWidth=2;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-olap" target="p2-sensitive">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1380" y="130" /><mxPoint x="1380" y="220" /></Array></mxGeometry>
        </mxCell>
        <!-- KMS -> sensitive bucket -->
        <mxCell id="p2-ekms" value="encrypts objects (per-patient)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#9673a6;strokeWidth=2;fontSize=10;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=1;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-kms" target="p2-sensitive">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="2050" y="745" /><mxPoint x="2050" y="350" /></Array></mxGeometry>
        </mxCell>
        <!-- KMS -> deident bucket -->
        <mxCell id="p2-ekms2" value="encrypts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#9673a6;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-kms" target="p2-deident">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1800" y="650" /></Array></mxGeometry>
        </mxCell>
        <!-- SG-as-source ingress: app SG -> endpoints SG -->
        <mxCell id="p2-esg-app" value="443 (SG src)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;strokeColor=#b85450;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="p2-wl" source="p2-appsg" target="p2-epsg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- SG-as-source ingress: on-prem node SG -> endpoints SG (cross-VPC) -->
        <mxCell id="p2-esg-onprem" value="443 (SG src, cross-VPC over peering)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;strokeColor=#b85450;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-onprem-sg" target="p2-epsg">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="1080" /><mxPoint x="1530" y="1080" /><mxPoint x="1530" y="615" /></Array></mxGeometry>
        </mxCell>

        <!-- ===================== ANNOTATIONS ===================== -->
        <mxCell id="p2-note1" value="&#9888; gateway endpoints aren&#39;t reachable across peering &#8594; on-prem [11] must use the INTERFACE endpoint [19] (ENI-backed, private DNS)." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontStyle=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=8;spacingTop=6;fontColor=#7a6a00;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2-note2" value="&#9888; VPC peering [26] is non-transitive &amp; N&#178; (each new VPC = new peering + route entries both sides). Transit Gateway is the scalable successor (PrivateLink for a single endpoint service is the other option)." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontStyle=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=8;spacingTop=6;fontColor=#7a6a00;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="480" height="90" as="geometry" />
        </mxCell>

        <!-- ===================== LEGEND ===================== -->
        <mxCell id="p2-legend" value="THE 4 PATHS TO [20] phi-sensitive&#10;P1 &#8212; Lambda redactor [14] &#8594; Object Lambda AP [23] &#8594; bucket; returns REDACTED only (C2).&#10;P2 &#8212; on-prem k3s [11] &#8594; peering [26] &#8594; S3 INTERFACE endpoint [19] &#8594; bucket (full object).&#10;P3 &#8212; EC2 web app [15] (instance role, SSM-only) &#8594; S3 GATEWAY endpoint [18] &#8594; bucket; ONLY human read path (C1).&#10;P4 &#8212; &quot;s3&quot; reader role [16] direct read, gated aws:sourceVpce==[18] (R13).&#10;&#10;[25] phi-deident is the org-wide de-identified copy (no VPC condition) &#8212; demonstrates the VPC-condition delta (C4).&#10;Controls docs: docs/data-plane-paths.md, docs/encryption-and-tokenization.md." style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="730" width="480" height="290" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3. Identity &amp; MFA" id="ith-page-3">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="p3-title" value="Page 3 &#8212; Identity &amp; Phishing-resistant MFA (R2, R3, R10, R13)" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p3-sub" value="Primary flow top &#8594; bottom: Entra (IdP) federates into AWS IAM Identity Center, which grants 3 permission sets. Login URL: https://d-96677e53fe.awsapps.com/start/" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;whiteSpace=wrap;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1200" height="22" as="geometry" />
        </mxCell>

        <!-- ===== Entra IdP ===== -->
        <mxCell id="p3-entra" value="[40] Microsoft Entra ID  (the IdP)&#10;tenant delicatehug.com &#183; AAD_PREMIUM P1&#10;(Conditional Access + auth strengths available)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="110" width="460" height="100" as="geometry" />
        </mxCell>

        <!-- ===== Conditional Access (side, disabled) ===== -->
        <mxCell id="p3-ca" value="[41] Conditional Access policy&#10;&#8226; Grant requires authentication strength = Phishing-resistant MFA&#10;&#160;&#160;(FIDO2 / passkey / WHfB / CBA)&#10;&#8226; Block sign-in that does NOT satisfy the strength (non-MFA blocked, R3)&#10;&#8226; Scope: interview-admins group on the AWS access app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="90" width="540" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p3-ca-flag" value="&#9888; Written as IaC but DISABLED&#10;(enable_entra_changes = false &#8212; no-breaking-changes guardrail; documented as suggested, not enabled)" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontColor=#7a6a00;" vertex="1" parent="1">
          <mxGeometry x="1080" y="260" width="540" height="60" as="geometry" />
        </mxCell>

        <!-- ===== Identity Center ===== -->
        <mxCell id="p3-idc" value="[42] AWS IAM Identity Center&#10;instance ssoins-46812a8&#8230; &#183; identity store d-96677e53fe (mgmt acct 337066574719)&#10;Login URL: https://d-96677e53fe.awsapps.com/start/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="320" width="500" height="100" as="geometry" />
        </mxCell>

        <!-- ===== Permission sets container ===== -->
        <mxCell id="p3-psgrp" value="[43] Permission sets (created for real; inert until assigned &#8212; assignments doc-only)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#eef5ff;strokeColor=#6c8ebf;dashed=1;fontStyle=1;fontSize=13;container=1;collapsible=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="520" width="1260" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p3-ps-super" value="[44] ITH-SuperAdmin&#10;AdministratorAccess, but a PERMISSIONS BOUNDARY&#10;caps the max to all-except-kms:* (no KMS, no Deny &#8212; a ceiling).&#10;User: ith-superadmin@&#8230;&#10;Reads details via EC2 web UI (P3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="p3-psgrp">
          <mxGeometry x="40" y="50" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p3-ps-admin" value="[45] ITH-Admin&#10;Scoped to relevant services (S3, EC2/VPC,&#10;CloudWatch, CloudTrail, GuardDuty-read).&#10;EXPLICIT DENY kms:*&#10;User: ith-admin@&#8230;&#10;Reads details via EC2 web UI (P3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="p3-psgrp">
          <mxGeometry x="450" y="50" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p3-ps-s3" value="[46] ITH-S3Reader&#10;S3 read ONLY when aws:sourceVpce matches&#10;(in-VPC only); denied otherwise.&#10;User: ith-s3@&#8230;&#10;Reads via EC2 web UI (P3) + in-VPC CLI (P4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="p3-psgrp">
          <mxGeometry x="860" y="50" width="360" height="160" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="p3-e-scim" value="SCIM provisioning + SAML federation" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p3-entra" target="p3-idc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e-ca" value="enforces MFA at sign-in (when enabled)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#b85450;fontSize=11;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p3-ca-flag" target="p3-entra">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1030" y="290" /><mxPoint x="1030" y="160" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="p3-e-grant" value="grants" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;strokeWidth=2;fontSize=12;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p3-idc" target="p3-psgrp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Legend ===== -->
        <mxCell id="p3-legend" value="LEGEND &amp; NOTES&#10;&#8226; Entra [40] is the IdP; users are SCIM-provisioned into Identity Center [42] which federates via SAML (R10).&#10;&#8226; Phishing-resistant MFA + non-MFA block live in the CA policy [41] &#8212; written as IaC, left DISABLED to protect the live tenant (R2/R3 doc-only).&#10;&#8226; 3 permission sets [44]/[45]/[46] map to the 3 users; least-privilege deltas: Admin denies kms:*, S3Reader is in-VPC only (R13).&#10;&#8226; All 3 humans read patient DETAILS only via the EC2 web UI (Page 2, P3 / C1). Controls doc: docs/identity-and-mfa.md." style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="800" width="1260" height="150" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="4. Detect &amp; Respond" id="ith-page-4">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="p4-title" value="Page 4 &#8212; Detect &amp; Respond (R4, R11, R12)" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub" value="Two detection chains converge on one SNS topic [55]; response levers on the right. Primary flow left &#8594; right. Account-level (not org delegated) per the guardrail." style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;whiteSpace=wrap;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1500" height="22" as="geometry" />
        </mxCell>

        <!-- ===================== CHAIN A: CloudTrail ===================== -->
        <mxCell id="p4-trail" value="[50] CloudTrail &quot;ith-trail&quot;&#10;multi-region &#183; log-file validation&#10;KMS-encrypted &#183; S3 data events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p4-cwl" value="[51] CloudWatch Logs&#10;/ith/cloudtrail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="400" y="125" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p4-mf" value="[52] 9 metric-filter alarms&#10;root usage &#183; console-without-MFA &#183; unauthorized API&#10;IAM/policy change &#183; S3 policy change &#183; KMS disable/sched-delete&#10;CloudTrail tamper &#183; GuardDuty high-sev &#183; AssumeRole-from-unexpected-IP&#10;(+ S3 4xx/AccessDenied spike, SG change)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="440" height="130" as="geometry" />
        </mxCell>

        <!-- ===================== CHAIN B: GuardDuty ===================== -->
        <mxCell id="p4-gd" value="[53] GuardDuty detector (all features)&#10;Managed threat detection — also satisfies R12:&#10;InstanceCredentialExfiltration.OutsideAWS / .InsideAWS&#10;(EC2 role creds used off the instance — by IP or by account)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p4-eb-gd" value="[54] EventBridge rule&#10;GuardDuty finding severity &gt;= 4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- ===================== SNS (convergence) ===================== -->
        <mxCell id="p4-sns" value="[55] SNS &quot;ith-security-alerts&quot;&#10;KMS-encrypted&#10;&#8594; email subscription" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1280" y="300" width="320" height="120" as="geometry" />
        </mxCell>

        <!-- ===================== RESPONSE LEVERS ===================== -->
        <mxCell id="p4-resp" value="[58] Response levers (assume-breach)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#fdecea;strokeColor=#b85450;dashed=1;fontStyle=1;fontSize=13;container=1;collapsible=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1740" y="120" width="320" height="500" as="geometry" />
        </mxCell>
        <mxCell id="p4-r1" value="[59] Disable a per-patient KMS key&#10;&#8594; exactly ONE patient goes dark&#10;(per-subject containment / erasure)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p4-resp">
          <mxGeometry x="20" y="60" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p4-r2" value="[60] Revoke credentials&#10;(rotate / disable access keys,&#10;deny-all on the session)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p4-resp">
          <mxGeometry x="20" y="190" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p4-r3" value="[61] Quarantine security group&#10;(swap instance/ENI to a no-ingress&#10;/no-egress SG to isolate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p4-resp">
          <mxGeometry x="20" y="320" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- ===================== EDGES ===================== -->
        <!-- Chain A -->
        <mxCell id="p4-eA1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-trail" target="p4-cwl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4-eA2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-cwl" target="p4-mf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4-eA3" value="alarm &#8594; notify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-mf" target="p4-sns">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1440" y="165" /><mxPoint x="1440" y="300" /></Array></mxGeometry>
        </mxCell>
        <!-- Chain B -->
        <mxCell id="p4-eB1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-gd" target="p4-eb-gd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4-eB2" value="sev &gt;= 4 &#8594; notify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-eb-gd" target="p4-sns">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1000" y="360" /></Array></mxGeometry>
        </mxCell>
        <!-- SNS -> response levers (operator-driven) -->
        <mxCell id="p4-eResp" value="operator triggers" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p4-sns" target="p4-resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Legend ===== -->
        <mxCell id="p4-legend" value="LEGEND &amp; NOTES&#10;&#8226; Chain A: CloudTrail [50] &#8594; CW Logs [51] &#8594; 9 metric-filter alarms [52] &#8594; SNS [55] (R4, R11).&#10;&#8226; Chain B: GuardDuty [53] &#8594; EventBridge sev&gt;=4 [54] &#8594; SNS [55] (R11). GuardDuty&#39;s InstanceCredentialExfiltration.OutsideAWS / .InsideAWS findings now satisfy R12 (EC2 role credentials used off the instance, detected by source IP or by AWS account).&#10;&#8226; Response levers [58]: disable one patient&#39;s KMS key [59] (one patient dark), revoke creds [60], quarantine SG [61].&#10;&#8226; Account-level (not org delegated admin) per the no-breaking-changes guardrail. Controls doc: docs/detection-and-response.md." style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="1560" height="170" as="geometry" />
        </mxCell>

