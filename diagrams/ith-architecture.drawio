        <mxCell id="p2-ifgrp-note" value="protected by endpoints SG [21]; enable SSM (no SSH) &amp; private control-plane calls" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#7a6a00;" vertex="1" parent="p2-ifgrp">
          <mxGeometry x="20" y="95" width="520" height="40" as="geometry" />
        </mxCell>

        <!-- Object Lambda Access Point -->
        <mxCell id="p2-olap" value="[23] S3 Object Lambda Access Point&#10;&quot;ith-sensitive-ap&quot;&#10;invokes [14] redactor on GetObject" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p2-wl">
          <mxGeometry x="420" y="60" width="300" height="100" as="geometry" />
        </mxCell>

        <!-- ===================== KMS column ===================== -->
        <mxCell id="p2-kms" value="[24] KMS &#8212; per-patient CMKs&#10;alias/ith/patient/*&#10;(one CMK per patient &#8212; R15)&#10;encrypts objects in [20];&#10;disable one key &#8594; one patient goes dark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1640" y="700" width="320" height="150" as="geometry" />
        </mxCell>

        <!-- ===================== BUCKETS ===================== -->
        <mxCell id="p2-sensitive" value="[20] S3  phi-sensitive-118821711925&#10;full ePHI (tokenized) &#8212; VPC-LOCKED&#10;bucket policy: GetObject only when aws:sourceVpce in {[18],[19]}&#10;SSE-KMS (per-patient CMK [24]) &#183; TLS-only &#183; BPA on (R1)" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="180" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p2-deident" value="[25] S3  phi-deident-118821711925&#10;de-identified copy &#8212; ORG-WIDE (no VPC condition)&#10;still org-locked (RCP), TLS-only, SSE-KMS (C4)" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
