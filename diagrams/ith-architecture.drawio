        <!-- ===================== ON-PREM VPC ===================== -->
        <mxCell id="p2-onprem" value="[10] On-prem VPC &#8212; 192.168.0.0/16  (has IGW / internet)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#fff5e6;strokeColor=#d79b00;dashed=1;fontStyle=1;fontSize=13;container=1;collapsible=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="380" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p2-k3s" value="[11] on-prem k3s node&#10;EC2 i-0a3dfcb0&#8230;&#10;(pod / node IAM role)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="p2-onprem">
          <mxGeometry x="40" y="60" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-onprem-sg" value="[12] on-prem node SG&#10;(used as SOURCE in endpoint SG ingress&#10;&#8212; SG-as-source over peering, R17)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;dashed=1;" vertex="1" parent="p2-onprem">
          <mxGeometry x="40" y="180" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-igw" value="IGW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="p2-onprem">
          <mxGeometry x="160" y="290" width="60" height="40" as="geometry" />
        </mxCell>

        <!-- ===================== WORKLOAD VPC ===================== -->
        <mxCell id="p2-wl" value="[13] Workload VPC &#8212; 10.20.0.0/16  (NO internet &#8212; no IGW / no NAT)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#eef5ff;strokeColor=#6c8ebf;dashed=1;fontStyle=1;fontSize=13;container=1;collapsible=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="1000" height="900" as="geometry" />
        </mxCell>

        <!-- compute column inside workload VPC -->
        <mxCell id="p2-lambda" value="[14] Lambda &quot;ith-redactor&quot;&#10;(IAM-auth Function URL)&#10;exec role &#8594; reads via Object Lambda AP&#10;returns REDACTED / de-identified only (C2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p2-wl">
          <mxGeometry x="30" y="60" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2-ec2" value="[15] EC2 web app  i-004a7375&#8230;&#10;SSM Session Manager ONLY &#8212; no key pair, no SSH (C3)&#10;EC2 instance role reads S3 &#8212; the ONLY human read path (P3 / C1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p2-wl">
          <mxGeometry x="30" y="190" width="320" height="100" as="geometry" />
