        <!-- ===================== EDGES (paths) ===================== -->
        <!-- P2: k3s -> peering -> interface endpoint -->
        <mxCell id="p2-eP2a" value="P2 read across peering" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-k3s" target="p2-peer">
