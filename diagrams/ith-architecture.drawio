        <mxCell id="p2-s3role" value="[16] &quot;s3&quot; reader role&#10;direct S3 read (CLI/SDK)&#10;GATED on aws:sourceVpce == [18] (P4 / R13)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p2-wl">
          <mxGeometry x="30" y="320" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-appsg" value="[17] app / web SG&#10;(used as SOURCE in endpoint SG ingress &#8212; R17)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="p2-wl">
          <mxGeometry x="30" y="440" width="320" height="70" as="geometry" />
        </mxCell>

        <!-- endpoints column inside workload VPC -->
